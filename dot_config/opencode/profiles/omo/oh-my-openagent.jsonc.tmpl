        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        },
        {
          "model": "openai/gpt-5.5",
          "variant": "high"
        }
      ]
    },
    "momus": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "xhigh"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        }
      ]
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        }
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "xhigh"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "deep": {
      "model": "openai/gpt-5.6-sol",
      "variant": "high",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        },
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "artistry": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5"
        }
      ]
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "fallback_models": [
        {
          "model": "anthropic/claude-haiku-4-5"
        }
      ]
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        }
      ]
    },
    "unspecified-high": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        {
          "model": "openai/gpt-5.5",
          "variant": "medium"
        }
      ]
    },
    "writing": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  }
}
