#!/usr/bin/env bash
set -euo pipefail

directory=${1:-}
pr_number=${2:-}

if [[ -z "$directory" || -z "$pr_number" ]]; then
  printf 'usage: pr_review <directory> <pr-number>\n' >&2
  exit 2
fi

cd "$directory"

branch_name=$(gh pr view "$pr_number" --json headRefName --jq .headRefName)
base_branch=$(gh pr view "$pr_number" --json baseRefName --jq .baseRefName)

wt switch --no-cd "pr:$pr_number"

worktree_path=$(
  wt list --format=json \
    | jq -r --arg branch "$branch_name" 'first(.[] | select(.branch == $branch and .path) | .path) // empty'
)

if [[ -z "$worktree_path" ]]; then
  printf 'Could not resolve worktree path for PR %s (%s)\n' "$pr_number" "$branch_name" >&2
  exit 1
fi

git -C "$worktree_path" fetch origin "$base_branch"

session_name=$(basename "$worktree_path")
created_session=0

if ! tmux has-session -t "$session_name" 2>/dev/null; then
  created_session=1
  tmux new-session -d -s "$session_name" -c "$worktree_path" -n shell
fi

if [[ $created_session -eq 1 ]]; then
  tmux new-window -t "$session_name:1" -c "$worktree_path"
  tmux new-window -t "$session_name:2" -c "$worktree_path"
  tmux send-keys -t "$session_name:1" "nvim '+lua require(\"ghlite\").open_pr($pr_number)'" C-m
  tmux send-keys -t "$session_name:2" "opencode --agent review --prompt 'generate a summary for this PR'" C-m
fi

if [[ -z "${TMUX:-}" ]]; then
  tmux attach-session -t "$session_name"
else
  tmux switch-client -t "$session_name"
fi
