#!/usr/bin/env bash
set -euo pipefail

tab=$'\t'
roots=("$HOME/code" "$HOME/.config" "$HOME/worktrees")
existing_roots=()

for root in "${roots[@]}"; do
  if [[ -d "$root" ]]; then
    existing_roots+=("$root")
  fi
done

fzf_command=(fzf)
if [[ -n "${TMUX:-}" ]] && command -v fzf-tmux >/dev/null 2>&1; then
  fzf_command=(fzf-tmux -p 80%,70%)
fi

if ! command -v "${fzf_command[0]}" >/dev/null 2>&1; then
  printf 'find-code: %s is required\n' "${fzf_command[0]}" >&2
  exit 1
fi

preview_command="bash -lc 'directory=\$1; ls -la --color=always \"\$directory\"' bash {3}"
if command -v eza >/dev/null 2>&1; then
  preview_command="bash -lc 'directory=\$1; eza --all --git --icons --color=always \"\$directory\"' bash {3}"
fi

list_directories() {
  if ((${#existing_roots[@]} == 0)); then
    return 0
  fi

  if command -v fd >/dev/null 2>&1; then
    fd -H -d 1 -t d . "${existing_roots[@]}" 2>/dev/null || true
    return 0
  fi

  for root in "${existing_roots[@]}"; do
    find "$root" -mindepth 1 -maxdepth 1 -type d 2>/dev/null || true
  done
}

selection=$(
  {
    declare -A tmux_paths=()

    if command -v tmux >/dev/null 2>&1; then
      while IFS="$tab" read -r session_name session_path; do
        if [[ -z "$session_name" || -z "$session_path" ]]; then
          continue
        fi

        tmux_paths["$session_path"]=1
        printf 'tmux%s\033[34m\033[39m %s%s%s%s%s\n' "$tab" "$session_name" "$tab" "$session_path" "$tab" "$session_name"
      done < <(tmux list-sessions -F "#{session_name}${tab}#{session_path}" 2>/dev/null || true)
    fi

    while IFS= read -r directory; do
      if [[ -n "${tmux_paths[$directory]+x}" ]]; then
        continue
      fi

      printf 'dir%s\033[36m\033[39m %s%s%s%s\n' "$tab" "$directory" "$tab" "$directory" "$tab"
    done < <(list_directories)
  } | "${fzf_command[@]}" \
    --no-sort --ansi \
    --delimiter "$tab" --with-nth 2 \
    --border-label ' find-code ' --prompt '⚡  ' \
    --header '   tmux   directory  enter switch  tab/btab move' \
    --bind 'tab:down,btab:up' \
    --preview-window 'right:55%' \
    --preview "$preview_command"
) || exit_code=$?

exit_code=${exit_code:-0}
if [[ $exit_code -ne 0 || -z "$selection" ]]; then
  exit 0
fi

IFS="$tab" read -r kind _label target session_name <<<"$selection"

case "$kind" in
  tmux)
    if [[ -n "${TMUX:-}" ]]; then
      tmux switch-client -t "$session_name"
    else
      tmux attach-session -t "$session_name"
    fi
    ;;
  dir)
    tmux-sessionizer "$target"
    ;;
esac
