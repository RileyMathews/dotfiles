#!/usr/bin/env bash
set -euo pipefail

PROFILE_FILE="$HOME/.local/share/profile/current"
OPENCODE_AUTH_PATH="$HOME/.local/share/opencode/auth.json"
OPENCODE_AUTH_PROFILES_DIR="$HOME/.local/share/opencode/profiles"

usage() {
  printf 'Usage: profile <status|switch> [args]\n'
  printf '\n'
  printf 'Commands:\n'
  printf '  status\n'
  printf '  switch <profile-name>\n'
}

preflight() {
  if [[ ! -d "$OPENCODE_AUTH_PROFILES_DIR" ]]; then
    mkdir -p "$OPENCODE_AUTH_PROFILES_DIR"
  fi

  if [[ -e "$OPENCODE_AUTH_PATH" && ! -L "$OPENCODE_AUTH_PATH" ]]; then
    printf 'opencode auth.json is not a symlink. Move your current auth.json into the correct subdir before running this command\n' >&2
    exit 1
  fi
}

set_browser_handlers() {
  local browser=$1
  local mime

  for mime in \
    application/x-extension-htm \
    application/x-extension-html \
    application/x-extension-shtml \
    application/x-extension-xht \
    application/x-extension-xhtml \
    application/xhtml+xml \
    text/html \
    x-scheme-handler/chrome \
    x-scheme-handler/http \
    x-scheme-handler/https; do
    handlr set "$mime" "$browser"
  done
}

set_personal_profile() {
  local profile_name=$1

  printf '%s\n' "$profile_name" >"$PROFILE_FILE"
  set_browser_handlers helium.desktop
  ln --symbolic --force "$OPENCODE_AUTH_PROFILES_DIR/personal.json" "$OPENCODE_AUTH_PATH"

  profile_status
  exit 0
}

set_work_profile() {
  local profile_name=$1

  printf '%s\n' "$profile_name" >"$PROFILE_FILE"
  set_browser_handlers google-chrome.desktop
  ln --symbolic --force "$OPENCODE_AUTH_PROFILES_DIR/work.json" "$OPENCODE_AUTH_PATH"

  profile_status
  exit 0
}

profile_status() {
  if [[ -e "$PROFILE_FILE" ]]; then
    cat "$PROFILE_FILE"
    handlr list
    ls -al "$OPENCODE_AUTH_PATH"
  else
    printf '%s\n' "$PROFILE_FILE"
    printf 'profile file not found\n'
  fi
}

profile_switch() {
  local profile_name=${1:-}

  if [[ -z "$profile_name" ]]; then
    printf 'Usage: profile switch <profile-name>\n' >&2
    exit 1
  fi

  if [[ ! -e "$PROFILE_FILE" ]]; then
    mkdir -p "$(dirname "$PROFILE_FILE")"
    touch "$PROFILE_FILE"
  fi

  case "$profile_name" in
    personal)
      set_personal_profile "$profile_name"
      ;;
    work)
      set_work_profile "$profile_name"
      ;;
    *)
      printf 'profile %s not recognized\n' "$profile_name" >&2
      exit 1
      ;;
  esac
}

preflight

command_name=${1:-}

if [[ -z "$command_name" ]]; then
  usage
  exit 1
fi

shift

case "$command_name" in
  status)
    profile_status "$@"
    ;;
  switch)
    profile_switch "$@"
    ;;
  active)
    cat "$PROFILE_FILE"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    printf 'Unknown subcommand: %s\n' "$command_name" >&2
    usage
    exit 1
    ;;
esac
