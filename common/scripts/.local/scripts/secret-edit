#!/usr/bin/env bash

# secure-edit.sh - Edit age-encrypted files with neovim

set -euo pipefail

# Configuration
PRIVATE_KEY="${PRIVATE_KEY:-$HOME/.ssh/id_ed25519}"
PUBLIC_KEY="${PUBLIC_KEY:-$HOME/.ssh/id_ed25519.pub}"

# Check dependencies
command -v age >/dev/null 2>&1 || { echo "Error: age not installed" >&2; exit 1; }
command -v nvim >/dev/null 2>&1 || { echo "Error: neovim not installed" >&2; exit 1; }

# Validate arguments
if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <file-path>" >&2
    exit 1
fi

TARGET_FILE="$1"
TARGET_DIR=$(dirname "$TARGET_FILE")
TARGET_NAME=$(basename "$TARGET_FILE")

# Create temp file with unique name
TMP_FILE=$(mktemp "/tmp/secure-edit.XXXXXX")
trap 'rm -f "$TMP_FILE"' EXIT

# Convert SSH private key to age identity if needed
AGE_KEY=$(mktemp "/tmp/age-key.XXXXXX")
trap 'rm -f "$TMP_FILE" "$AGE_KEY"' EXIT

# Extract age identity from SSH key
ssh-keygen -p -N "" -m PEM -f "$PRIVATE_KEY" -e 2>/dev/null | \
    age-plugin-ssh --identity 2>/dev/null > "$AGE_KEY" 2>/dev/null || {
    # Fallback: try direct conversion
    age-plugin-ssh --identity "$PRIVATE_KEY" > "$AGE_KEY" 2>/dev/null || {
        echo "Error: Could not convert SSH key to age identity" >&2
        exit 1
    }
}

# Decrypt if file exists
if [[ -f "$TARGET_FILE" ]]; then
    echo "Decrypting $TARGET_FILE..."
    if ! age --decrypt --identity "$AGE_KEY" -o "$TMP_FILE" "$TARGET_FILE" 2>/dev/null; then
        echo "Error: Failed to decrypt $TARGET_FILE" >&2
        exit 1
    fi
    echo "Decrypted successfully"
else
    echo "Creating new file: $TARGET_FILE"
    # Ensure target directory exists
    mkdir -p "$TARGET_DIR"
fi

# Get original modification time
ORIG_MTIME=$(stat -c %Y "$TMP_FILE" 2>/dev/null || echo "0")

# Open in neovim
nvim "$TMP_FILE"

# Check if file was modified
NEW_MTIME=$(stat -c %Y "$TMP_FILE" 2>/dev/null || echo "0")

if [[ "$ORIG_MTIME" != "$NEW_MTIME" ]]; then
    echo "File modified, encrypting..."
    
    # Convert SSH public key to age recipient
    RECIPIENT=$(age-plugin-ssh --recipient "$PUBLIC_KEY" 2>/dev/null) || {
        echo "Error: Could not convert SSH public key to age recipient" >&2
        exit 1
    }
    
    # Encrypt and write back
    if age --encrypt --recipient "$RECIPIENT" -o "$TARGET_FILE" "$TMP_FILE"; then
        echo "Encrypted and saved to $TARGET_FILE"
    else
        echo "Error: Failed to encrypt file" >&2
        exit 1
    fi
else
    echo "No changes made"
fi
