#!/usr/bin/env bash

# secure-edit.sh - Edit age-encrypted files with neovim using SSH keys

set -euo pipefail

SSH_DIR="${SSH_DIR:-$HOME/.ssh}"
PRIVATE_KEY="${PRIVATE_KEY:-$SSH_DIR/id_ed25519}"
PUBLIC_KEY="${PUBLIC_KEY:-$SSH_DIR/id_ed25519.pub}"

command -v age >/dev/null 2>&1 || { echo "Error: age not installed" >&2; exit 1; }
command -v nvim >/dev/null 2>&1 || { echo "Error: neovim not installed" >&2; exit 1; }

if [[ $# -ne 1 ]]; then
    echo "Usage: $0 <file-path>" >&2
    exit 1
fi

TARGET_FILE="$1"
TMP_FILE=$(mktemp "/tmp/secure-edit.XXXXXX")
trap 'rm -f "$TMP_FILE"' EXIT

if [[ -f "$TARGET_FILE" ]]; then
    age --decrypt -i "$PRIVATE_KEY" -o "$TMP_FILE" "$TARGET_FILE"
else
    mkdir -p "$(dirname "$TARGET_FILE")"
fi

nvim "$TMP_FILE"
age --encrypt -R "$PUBLIC_KEY" -o "$TARGET_FILE" "$TMP_FILE"
