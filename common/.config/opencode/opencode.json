{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": ["CLAUDE.local.md"],
  "disabled_providers": [
    "github-models",
    "github-copilot-enterprise",
    "amazon-bedrock",
    "github-copilot",
    "opencode"
  ],
  "lsp": {
    "haskell-language-server": {
      "command": [],
      "extensions": [
        ".hs"
      ]
    },
    "tsgo": {
      "command": [],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    }
  },
  "mcp": {
    "forgejo": {
      "type": "local",
      "command": ["forgejo-mcp", "--url", "https://git.rileymathews.com"],
      "enabled": true
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/sse"
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    },
    "honeycomb": {
      "type": "remote",
      "url": "https://mcp.honeycomb.io/mcp",
      "oauth": {}
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "oauth": {}
    }
  },
  "permission": {
    "bash": {
      "make format": "deny",
      "*": "allow"
    }
  }
}
